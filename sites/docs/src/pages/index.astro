---
import "../styles/global.css";
import Header from '../components/Header';
---
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>Rin Documentation</title>
	</head>
	<body class="bg-gray-50 min-h-screen">
		<Header title="Rin Framework" client:load />
		<main class="p-8 max-w-4xl mx-auto">
			<h2 class="text-2xl font-semibold text-gray-800">Welcome to the future of minimalist web dev.</h2>
			<p class="mt-4 text-gray-600">
				Rin is a hyper-minimalist JSX framework designed for speed and simplicity. 
				This hello world page verifies our Astro, Tailwind v4, and Pagefind setup!
			</p>
		</main>
	</body>
</html>
